    {{-- RIGHT: Cart & Checkout --}}
    <div class="lg:w-2/3 flex flex-col gap-4">

        {{-- Cart Items --}}
        <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700 flex-1 overflow-y-auto">
            <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                Keranjang (<span x-text="cart.length"></span> item)
            </h3>
            <div class="space-y-2">
                <template x-for="(item, index) in cart" :key="index">
                    <div class="flex items-center gap-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-700/50">
                        <div class="flex-1">
                            <div class="font-medium text-gray-900 dark:text-white" x-text="item.name"></div>
                            <div class="text-sm text-gray-500 dark:text-gray-400" x-text="item.code"></div>
                        </div>
                        <div class="flex items-center gap-2">
                            <button @click="decreaseQty(index)" class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-600 hover:bg-gray-300 dark:hover:bg-gray-500 flex items-center justify-center text-gray-700 dark:text-white">-</button>
                            <span class="w-8 text-center font-bold" x-text="item.qty"></span>
                            <button @click="increaseQty(index)" class="w-8 h-8 rounded-full bg-blue-100 dark:bg-blue-900 hover:bg-blue-200 dark:hover:bg-blue-800 flex items-center justify-center text-blue-700 dark:text-blue-300">+</button>
                        </div>
                        <div class="text-right min-w-[100px]">
                            <div class="font-bold text-gray-900 dark:text-white" x-text="'Rp ' + formatNumber(item.price * item.qty)"></div>
                            <div class="text-xs text-gray-500" x-text="'@ Rp ' + formatNumber(item.price)"></div>
                        </div>
                        <button @click="removeFromCart(index)" class="w-8 h-8 rounded-full bg-red-100 dark:bg-red-900/30 hover:bg-red-200 dark:hover:bg-red-900/50 flex items-center justify-center text-red-600 dark:text-red-400">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                        </button>
                    </div>
                </template>
                <div x-show="cart.length === 0" class="text-center py-12 text-gray-400">
                    Keranjang kosong. Pilih barang dari sebelah kiri.
                </div>
            </div>
        </div>

        {{-- Summary & Checkout --}}
        <div class="bg-white dark:bg-gray-800 rounded-xl p-4 shadow-sm border border-gray-200 dark:border-gray-700">
            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="text-sm text-gray-500 dark:text-gray-400">Subtotal</label>
                    <div class="text-lg font-bold text-gray-900 dark:text-white" x-text="'Rp ' + formatNumber(subtotal)"></div>
                </div>
                <div>
                    <label class="text-sm text-gray-500 dark:text-gray-400">Diskon</label>
                    <input type="number" x-model.number="discount" @input="calculateChange()" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 px-3 py-2 dark:bg-gray-700 dark:text-white">
