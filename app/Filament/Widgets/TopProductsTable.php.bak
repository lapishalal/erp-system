<?php

namespace App\Filament\Widgets;

use App\Models\Product;
use Filament\Tables;
use Filament\Tables\Table;
use Filament\Widgets\TableWidget as BaseWidget;

class TopProductsTable extends BaseWidget
{
    protected int | string | array $columnSpan = 'full';
    protected static ?string $heading = 'Top Product';

    public function table(Table $table): Table
    {
        return $table
            ->query(
                Product::query()
                    ->select('products.*')
                    ->selectRaw('COALESCE((SELECT SUM(qty) FROM sales_order_details JOIN sales_orders ON sales_orders.id = sales_order_details.so_id WHERE sales_order_details.product_id = products.id AND sales_orders.status IN (\'OPEN\',\'PARTIAL\',\'COMPLETE\')), 0) as total_qty')
                    ->orderByDesc('total_qty')
                    ->limit(5)
            )
            ->columns([
                Tables\Columns\TextColumn::make('name')
                    ->label('Produk'),
                Tables\Columns\TextColumn::make('brand.name'),
                Tables\Columns\TextColumn::make('total_qty')
                    ->label('Qty Terjual'),
            ])
            ->paginated(false);
    }
}