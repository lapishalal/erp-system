<?php

namespace App\Filament\Resources;

use App\Filament\Resources\PayrollResource\Pages;
use App\Filament\Resources\PayrollResource\RelationManagers;
use App\Models\Payroll;
use Filament\Forms;
use Filament\Forms\Form;
use Filament\Resources\Resource;
use Filament\Tables;
use Filament\Tables\Table;
use Illuminate\Database\Eloquent\Builder;

class PayrollResource extends Resource
{
    protected static ?string $model = Payroll::class;
    protected static ?string $navigationIcon = 'heroicon-o-document-text';
    protected static ?string $navigationGroup = 'Keuangan';
    protected static ?string $navigationLabel = 'Slip Gaji';
    protected static ?string $modelLabel = 'Slip Gaji';
    protected static ?string $pluralModelLabel = 'Slip Gaji';

    public static function shouldRegisterNavigation(): bool
    {
        return auth()->user()->hasRole('Admin')
            || auth()->user()->hasPermissionTo('manage_payroll');
    }

    public static function form(Form $form): Form
    {
        return $form
            ->schema([
                Forms\Components\Section::make('Informasi')
                    ->columns(2)
                    ->schema([
                        Forms\Components\TextInput::make('payroll_number')
                            ->label('No. Slip')
                            ->disabled()
                            ->dehydrated(false),
                        Forms\Components\Select::make('employee_id')
                            ->label('Karyawan')
                            ->relationship('employee', 'name')
                            ->disabled()
                            ->dehydrated(false),
                        Forms\Components\Select::make('payroll_period_id')
                            ->label('Periode')
                            ->relationship('payrollPeriod', 'period_name')
                            ->disabled()
                            ->dehydrated(false),
                        Forms\Components\Select::make('status')
                            ->label('Status')
                            ->options([
                                'DRAFT' => 'Draft',
                                'PROCESSED' => 'Sudah Proses',
                                'PAID' => 'Sudah Dibayar',
                            ])
                            ->disabled(),
                    ]),

                Forms\Components\Section::make('Penghasilan (Otomatis dari Master)')
                    ->columns(3)
                    ->schema([
                        Forms\Components\TextInput::make('basic_salary')
                            ->label('Gaji Pokok')
                            ->numeric()
                            ->prefix('Rp')
                            ->disabled()
                            ->dehydrated(false),
                        Forms\Components\TextInput::make('total_allowances')
                            ->label('Total Tunjangan')
                            ->numeric()
                            ->prefix('Rp')
                            ->disabled()
                            ->dehydrated(false),
                        Forms\Components\TextInput::make('total_earnings')
                            ->label('Total Penghasilan')
                            ->numeric()
                            ->prefix('Rp')
                            ->disabled()
                            ->dehydrated(false),
                    ]),

                Forms\Components\Section::make('Potongan Manual (Bisa Diedit)')
                    ->description('Tambahkan potongan absensi, denda, atau potongan lain di sini.')
                    ->columns(3)
                    ->schema([
                        Forms\Components\TextInput::make('alpha_days')
                            ->label('Hari Alpha')
                            ->numeric()
                            ->default(0)
                            ->live()
                            ->helperText('Jumlah hari tidak masuk kerja')
                            ->afterStateUpdated(function (Forms\Set $set, Forms\Get $get) {
                                $days = (int) $get('alpha_days');
                                $basic = (float) $get('basic_salary');
                                if ($days > 0 && $basic > 0) {
                                    // Asumsi 25 hari kerja per bulan
                                    $deduction = round(($basic / 25) * $days, 2);
                                    $set('alpha_deduction', $deduction);
                                } else {
                                    $set('alpha_deduction', 0);
                                }
                            }),
                        Forms\Components\TextInput::make('alpha_deduction')
                            ->label('Potongan Alpha')
                            ->numeric()
                            ->prefix('Rp')
                            ->default(0)
                            ->live()
                            ->helperText('Otomatis dari hari alpha, bisa diubah manual'),
                        Forms\Components\TextInput::make('pph21_deduction')
                            ->label('PPh 21')
                            ->numeric()
                            ->prefix('Rp')
                            ->default(0),
                        Forms\Components\TextInput::make('loan_deduction')
                            ->label('Potongan Kasbon')
                            ->numeric()
                            ->prefix('Rp')
                            ->default(0)
                            ->disabled()
                            ->dehydrated()
                            ->helperText('Otomatis dari data kasbon aktif'),
                    ]),

                Forms\Components\Section::make('Ringkasan')
                    ->columns(3)
                    ->schema([
                        Forms\Components\TextInput::make('total_deductions')
                            ->label('Total Potongan')
                            ->numeric()
                            ->prefix('Rp')
                            ->disabled(),
                        Forms\Components\TextInput::make('net_salary')
                            ->label('Gaji Bersih')
                            ->numeric()
                            ->prefix('Rp')
                            ->disabled()
                            ->helperText('Auto update: Penghasilan - Total Potongan'),
                        Forms\Components\Textarea::make('notes')
                            ->label('Catatan')
                            ->columnSpanFull(),
                    ]),
            ]);
    }

    public static function table(Table $table): Table
    {
        return $table
            ->modifyQueryUsing(fn (Builder $query) => $query->with(['employee', 'payrollPeriod']))
            ->columns([
                Tables\Columns\TextColumn::make('payroll_number')
                    ->searchable()
                    ->sortable(),
                Tables\Columns\TextColumn::make('employee.name')
                    ->searchable()
                    ->sortable(),
                Tables\Columns\TextColumn::make('payrollPeriod.period_name')
                    ->label('Periode'),
                Tables\Columns\TextColumn::make('basic_salary')
                    ->label('Gaji Pokok')
                    ->money('IDR')
                    ->alignEnd(),
                Tables\Columns\TextColumn::make('total_earnings')
                    ->label('Penghasilan')
                    ->money('IDR')
                    ->alignEnd(),
                Tables\Columns\TextColumn::make('total_deductions')
                    ->label('Potongan')
                    ->money('IDR')
                    ->alignEnd()
                    ->color('danger'),
                Tables\Columns\TextColumn::make('net_salary')
                    ->label('Gaji Bersih')
                    ->money('IDR')
                    ->alignEnd()
                    ->weight('bold'),
                Tables\Columns\TextColumn::make('status')
                    ->badge()
                    ->color(fn (string $state): string => match($state) {
                        'DRAFT' => 'gray',
                        'PROCESSED' => 'warning',
                        'PAID' => 'success',
                        default => 'gray',
                    }),
            ])
            ->filters([
                Tables\Filters\SelectFilter::make('payroll_period_id')
                    ->label('Periode')
                    ->relationship('payrollPeriod', 'period_name')
                    ->searchable()
                    ->preload(),
                Tables\Filters\SelectFilter::make('status')
                    ->options([
                        'DRAFT' => 'Draft',
                        'PROCESSED' => 'Sudah Proses',
                        'PAID' => 'Sudah Dibayar',
                    ]),
            ])
            ->actions([
                Tables\Actions\EditAction::make()
                    ->visible(fn (Payroll $record): bool => $record->status === 'DRAFT'),
                Tables\Actions\ViewAction::make(),
            ])
            ->bulkActions([
                Tables\Actions\BulkActionGroup::make([
                    Tables\Actions\DeleteBulkAction::make(),
                ]),
            ]);
    }

    public static function getRelations(): array
    {
        return [
            RelationManagers\DetailsRelationManager::class,
        ];
    }

    public static function getPages(): array
    {
        return [
            'index' => Pages\ListPayrolls::route('/'),
            'edit' => Pages\EditPayroll::route('/{record}/edit'),
            'view' => Pages\ViewPayroll::route('/{record}'),
        ];
    }
}