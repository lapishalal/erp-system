<?php

namespace App\Services;

use App\Models\DeliveryOrder;
use App\Models\DeliveryOrderDetail;
use App\Models\SalesOrder;
use App\Models\Warehouse;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Log;

class MarketplaceDeliveryOrderCreator
{
    public function createFromSalesOrder(SalesOrder $salesOrder): ?DeliveryOrder
    {
        return DB::transaction(function () use ($salesOrder) {
            $exists = DeliveryOrder::where('tenant_id', $salesOrder->tenant_id)
                ->where('so_id', $salesOrder->id)
                ->exists();

            if ($exists) {
                Log::info('DO already exists for SO', ['so_id' => $salesOrder->id]);
                return null;
            }

            $warehouse = Warehouse::where('tenant_id', $salesOrder->tenant_id)
                ->where('is_active', true)
                ->orderBy('id')
                ->first();

            $warehouseId = $warehouse?->id;

            $doNumber = $this->generateDoNumber($salesOrder->tenant_id);

            $totalQty = $salesOrder->details()->sum('qty');

            $deliveryOrder = DeliveryOrder::create([
                'tenant_id' => $salesOrder->tenant_id,
                'do_number' => $doNumber,
                'so_id' => $salesOrder->id,
                'date' => now(),
                'customer_id' => $salesOrder->customer_id,
                'warehouse_id' => $warehouseId,
                'status' => 'DRAFT',
                'total_qty' => $totalQty,
                'notes' => "Auto-generated from {$salesOrder->source} SO: {$salesOrder->so_number}",
                'driver' => null,
                'vehicle' => null,
                'created_by' => null,
            ]);

            foreach ($salesOrder->details as $detail) {
                DeliveryOrderDetail::create([
                    'tenant_id' => $salesOrder->tenant_id,
                    'do_id' => $deliveryOrder->id,
                    'product_id' => $detail->product_id,
                    'qty' => $detail->qty,
                    'notes' => null,
                ]);
            }

            Log::info('DO created from marketplace SO', [
                'do_id' => $deliveryOrder->id,
                'do_number' => $doNumber,
                'so_id' => $salesOrder->id,
            ]);

            return $deliveryOrder;
        });
    }

    private function generateDoNumber(string $tenantId): string
    {
        $prefix = 'DO-MKT-' . date('Ymd');
        $last = DeliveryOrder::where('tenant_id', $tenantId)
            ->where('do_number', 'like', $prefix . '%')
            ->orderBy('id', 'desc')
            ->value('do_number');

        $sequence = 1;
        if ($last) {
            $parts = explode('-', $last);
            $sequence = (int) end($parts) + 1;
        }

        return $prefix . '-' . str_pad((string) $sequence, 4, '0', STR_PAD_LEFT);
    }
}