<?php

namespace App\Services;

use App\Enums\MarketplacePlatform;
use App\Models\Customer;
use App\Models\MarketplaceOrder;
use App\Models\Product;
use App\Models\SalesOrder;
use App\Models\SalesOrderDetail;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Log;

class MarketplaceOrderProcessor
{
    public function process(MarketplaceOrder $marketplaceOrder): ?SalesOrder
    {
        return DB::transaction(function () use ($marketplaceOrder) {
            $payload = $marketplaceOrder->raw_payload;
            $tenantId = $marketplaceOrder->tenant_id;
            $platform = $marketplaceOrder->platform;

            // 1. Ambil items dari payload
            $items = $this->extractItems($payload, $platform);

            if (empty($items)) {
                Log::warning('MarketplaceOrderProcessor: no items found', [
                    'marketplace_order_id' => $marketplaceOrder->id,
                    'payload_keys' => array_keys($payload),
                ]);
                return null;
            }

            // 2. Mapping SKU ke Product
            $mappedItems = [];
            $allMapped = true;

            foreach ($items as $item) {
                $sku = $item['sku'] ?? $item['sku_id'] ?? $item['sku_code'] ?? null;
                
                Log::info('Mapping SKU', ['sku' => $sku, 'tenant_id' => $tenantId]);

                $product = Product::where('tenant_id', $tenantId)
                    ->where('sku', $sku)
                    ->first();

                if (!$product) {
                    $allMapped = false;
                    Log::warning('MarketplaceOrderProcessor: SKU not found', [
                        'sku' => $sku,
                        'tenant_id' => $tenantId,
                    ]);
                    continue;
                }

                $mappedItems[] = [
                    'product_id' => $product->id,
                    'qty' => (int) ($item['qty'] ?? $item['quantity'] ?? 1),
                    'unit_price' => (float) ($item['price'] ?? $item['sale_price'] ?? $item['unit_price'] ?? 0),
                    'cost_price' => $product->cost_price ?? 0,
                ];
            }

            // 3. Simpan mapping status
            $marketplaceOrder->update([
                'is_mapped' => $allMapped && count($mappedItems) === count($items),
                'mapped_items' => $mappedItems,
            ]);

            if (empty($mappedItems)) {
                Log::warning('MarketplaceOrderProcessor: no items mapped', [
                    'marketplace_order_id' => $marketplaceOrder->id,
                ]);
                return null;
            }

            // 4. Buat atau ambil Customer generic
            $customer = $this->getOrCreateMarketplaceCustomer($tenantId, $platform);

            // 5. Hitung total
            $totalQty = collect($mappedItems)->sum('qty');
            $totalAmount = collect($mappedItems)->sum(fn($i) => $i['qty'] * $i['unit_price']);
            $totalCost = collect($mappedItems)->sum(fn($i) => $i['qty'] * $i['cost_price']);

            // 6. Generate SO Number
            $soNumber = $this->generateSoNumber($tenantId);

            // 7. Buat Sales Order
            $salesOrder = SalesOrder::create([
                'tenant_id' => $tenantId,
                'so_number' => $soNumber,
                'date' => now(),
                'customer_id' => $customer->id,
                'status' => 'OPEN',
                'source' => $platform->value,
                'total_qty' => $totalQty,
                'total_amount' => $totalAmount,
                'total_cost' => $totalCost,
                'profit' => $totalAmount - $totalCost,
                'notes' => "Auto-generated from {$platform->value} order: {$marketplaceOrder->platform_order_id}",
                'created_by' => null,
                'approved_by' => null,
            ]);

            // 8. Buat Sales Order Details
            foreach ($mappedItems as $item) {
                $subtotal = $item['qty'] * $item['unit_price'];
                $profit = $subtotal - ($item['qty'] * $item['cost_price']);

                SalesOrderDetail::create([
                    'tenant_id' => $tenantId,
                    'so_id' => $salesOrder->id,
                    'product_id' => $item['product_id'],
                    'qty' => $item['qty'],
                    'unit_price' => $item['unit_price'],
                    'cost_price' => $item['cost_price'],
                    'delivered_qty' => 0,
                    'remaining_qty' => $item['qty'],
                    'subtotal' => $subtotal,
                    'profit' => $profit,
                ]);
            }

            // 9. Update marketplace order
            $marketplaceOrder->update([
                'sales_order_id' => $salesOrder->id,
                'processed_at' => now(),
            ]);

            // 10. Auto Create DO
            try {
                $doCreator = app(MarketplaceDeliveryOrderCreator::class);
                $doCreator->createFromSalesOrder($salesOrder);
            } catch (\Throwable $e) {
                Log::warning('Auto DO creation failed, but SO created', [
                    'error' => $e->getMessage(),
                    'so_id' => $salesOrder->id,
                ]);
            }

            Log::info('MarketplaceOrderProcessor: SO + DO created', [
                'so_id' => $salesOrder->id,
                'so_number' => $soNumber,
                'marketplace_order_id' => $marketplaceOrder->id,
            ]);

            return $salesOrder;
        });
    }

    private function extractItems(array $payload, MarketplacePlatform $platform): array
    {
        if ($platform === MarketplacePlatform::TIKTOK) {
            // Coba beberapa kemungkinan struktur payload
            $items = $payload['data']['item_list'] 
                ?? $payload['item_list'] 
                ?? $payload['items'] 
                ?? $payload['data']['items'] 
                ?? [];
            
            // Format ulang kalau perlu
            return collect($items)->map(function ($item) {
                return [
                    'sku' => $item['sku_id'] ?? $item['sku'] ?? null,
                    'qty' => $item['quantity'] ?? $item['qty'] ?? 1,
                    'price' => $item['sale_price'] ?? $item['price'] ?? 0,
                ];
            })->toArray();
        }

        // Shopee
        $data = $payload['data'] ?? $payload;
        $items = $data['items'] ?? $data['item_list'] ?? [];
        
        return collect($items)->map(function ($item) {
            return [
                'sku' => $item['item_sku'] ?? $item['sku'] ?? $item['model_sku'] ?? null,
                'qty' => $item['variation_quantity_purchased'] ?? $item['quantity'] ?? 1,
                'price' => $item['model_original_price'] ?? $item['price'] ?? 0,
            ];
        })->toArray();
    }

    private function getOrCreateMarketplaceCustomer(string $tenantId, MarketplacePlatform $platform): Customer
    {
        $code = 'MKT-' . strtoupper($platform->value);
        $name = match ($platform) {
            MarketplacePlatform::TIKTOK => 'TikTok Shop Customer',
            MarketplacePlatform::SHOPEE => 'Shopee Customer',
        };

        return Customer::firstOrCreate(
            [
                'tenant_id' => $tenantId,
                'code' => $code,
            ],
            [
                'name' => $name,
                'address' => '-',
                'phone' => '-',
                'email' => null,
                'pic' => '-',
                'credit_limit' => 0,
                'outstanding_amount' => 0,
                'is_active' => true,
            ]
        );
    }

    private function generateSoNumber(string $tenantId): string
    {
        $prefix = 'SO-MKT-' . date('Ymd');
        $last = SalesOrder::where('tenant_id', $tenantId)
            ->where('so_number', 'like', $prefix . '%')
            ->orderBy('id', 'desc')
            ->value('so_number');

        $sequence = 1;
        if ($last) {
            $parts = explode('-', $last);
            $sequence = (int) end($parts) + 1;
        }

        return $prefix . '-' . str_pad((string) $sequence, 4, '0', STR_PAD_LEFT);
    }
}