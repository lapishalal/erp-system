<?php

namespace App\Services;

use Illuminate\Support\Facades\Http;
use Illuminate\Support\Facades\Log;

class AiParserService
{
    protected string $apiKey;
    protected string $model;
    protected string $baseUrl;

    public function __construct()
    {
        $this->apiKey = config('services.gemini.api_key');
        $this->model = config('services.gemini.model', 'gemini-2.0-flash');
        $this->baseUrl = config('services.gemini.api_url', 'https://generativelanguage.googleapis.com/v1beta/models');
    }

    /**
     * Parse text pesanan ke JSON
     */
    public function parseOrderText(string $text): array
    {
        $prompt = <<<PROMPT
Kamu adalah parser pesanan untuk sistem ERP. Extract data dari input user menjadi JSON.

Input user bisa berupa:
- Format bebas: "sabun mandi 5 harga 42rb, shampoo 3 harga 35rb"
- Format terstruktur: "Nama/Qty/Harga"
- Campuran: "sabun mandi/5/42000, shampoo 3 harga 35.000"

Rules:
1. Harga "42rb", "42.000", "42000", "42.000,-" → 42000 (integer)
2. Qty "5 pcs", "5", "lima" → 5 (integer)
3. Nama produk: kembalikan nama asli dari input (tidak perlu match database)
4. Jika harga tidak disebut, set 0
5. Jika ada catatan tambahan (contoh: "kirim besok", "harga nego"), masukkan ke "notes"

Return JSON MURNI tanpa markdown, tanpa penjelasan:
{
  "items": [
    {"name": "string", "qty": 5, "price": 42000}
  ],
  "notes": "string"
}
PROMPT;

        return $this->callGemini($prompt, $text);
    }

    /**
     * Parse foto struk ke JSON
     */
    public function parseOrderImage(string $base64Image, string $mimeType = 'image/jpeg'): array
    {
        $prompt = <<<PROMPT
Kamu adalah OCR + parser untuk struk pesanan/invoice. Baca gambar struk ini dan extract:

1. Nama item/produk
2. Qty (jumlah)
3. Harga satuan atau harga total per item
4. Catatan tambahan (kalau ada)

Rules:
- Jika harga total per item ada, bagi dengan qty untuk dapat harga satuan
- Harga dalam rupiah, hilangkan titik/ribuan
- Ignore: header, footer, total keseluruhan, pajak, diskon global
- Return JSON MURNI:

{
  "items": [
    {"name": "string", "qty": 5, "price": 42000}
  ],
  "notes": "string"
}
PROMPT;

        return $this->callGeminiWithImage($prompt, $base64Image, $mimeType);
    }

    protected function callGemini(string $systemPrompt, string $userInput): array
    {
        if (empty($this->apiKey)) {
            Log::error('GEMINI_API_KEY kosong');
            return ['error' => 'API key not configured'];
        }

        $url = "{$this->baseUrl}/{$this->model}:generateContent?key={$this->apiKey}";

        try {
            $response = Http::timeout(30)->post($url, [
                'contents' => [
                    [
                        'role' => 'user',
                        'parts' => [
                            ['text' => $systemPrompt . "\n\nInput user:\n" . $userInput]
                        ]
                    ]
                ],
                'generationConfig' => [
                    'temperature' => 0.1,
                    'maxOutputTokens' => 2048,
                    'responseMimeType' => 'application/json',
                ],
            ]);

            if (!$response->successful()) {
                Log::error('Gemini API error', ['status' => $response->status(), 'body' => $response->body()]);
                return ['error' => 'Gemini API error: ' . $response->body()];
            }

            $jsonText = $response->json('candidates.0.content.parts.0.text', '');
            
            // Bersihkan kalau masih ada markdown
            $jsonText = preg_replace('/^```json\s*/', '', $jsonText);
            $jsonText = preg_replace('/\s*```$/', '', $jsonText);

            $parsed = json_decode($jsonText, true);
            if (json_last_error() !== JSON_ERROR_NONE) {
                Log::error('Gemini JSON parse error', ['raw' => $jsonText]);
                return ['error' => 'Failed to parse AI response'];
            }

            return $parsed;

        } catch (\Exception $e) {
            Log::error('Gemini exception: ' . $e->getMessage());
            return ['error' => $e->getMessage()];
        }
    }

    protected function callGeminiWithImage(string $systemPrompt, string $base64Image, string $mimeType): array
    {
        if (empty($this->apiKey)) {
            return ['error' => 'API key not configured'];
        }

        $url = "{$this->baseUrl}/{$this->model}:generateContent?key={$this->apiKey}";

        try {
            $response = Http::timeout(60)->post($url, [
                'contents' => [
                    [
                        'role' => 'user',
                        'parts' => [
                            ['text' => $systemPrompt],
                            [
                                'inline_data' => [
                                    'mime_type' => $mimeType,
                                    'data' => $base64Image,
                                ]
                            ]
                        ]
                    ]
                ],
                'generationConfig' => [
                    'temperature' => 0.1,
                    'maxOutputTokens' => 2048,
                    'responseMimeType' => 'application/json',
                ],
            ]);

            if (!$response->successful()) {
                Log::error('Gemini image API error', ['status' => $response->status(), 'body' => $response->body()]);
                return ['error' => 'Gemini API error: ' . $response->body()];
            }

            $jsonText = $response->json('candidates.0.content.parts.0.text', '');
            $jsonText = preg_replace('/^```json\s*/', '', $jsonText);
            $jsonText = preg_replace('/\s*```$/', '', $jsonText);

            $parsed = json_decode($jsonText, true);
            if (json_last_error() !== JSON_ERROR_NONE) {
                Log::error('Gemini image JSON parse error', ['raw' => $jsonText]);
                return ['error' => 'Failed to parse AI response'];
            }

            return $parsed;

        } catch (\Exception $e) {
            Log::error('Gemini image exception: ' . $e->getMessage());
            return ['error' => $e->getMessage()];
        }
    }
}